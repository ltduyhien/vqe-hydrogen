# .gitignore for vqe-hydrogen.
# Sections: Python/pip artifacts, Qiskit/Jupyter noise, internal docs, editor/OS noise.


# Python build / runtime

__pycache__/
*.py[cod]
*$py.class
*.so

build/
dist/
*.egg-info/
*.egg
.eggs/
wheels/
pip-wheel-metadata/
MANIFEST

pip-log.txt
pip-delete-this-directory.txt

# Test / coverage caches
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
nosetests.xml
coverage.xml
*.cover
*.py,cover

# Virtualenvs; recreate per machine.
.env
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/


# Qiskit / Jupyter / experiment outputs

.ipynb_checkpoints/

# IBM Quantum credentials -- never commit these.
qiskit-ibm.json
*.qiskit-ibm.json

# Local outputs (plots, serialized results). Regenerate from code.
results/
outputs/
*.npz
*.npy
*.pkl


# Internal working doc. Stays in the dev's working tree, never committed.
# Ignored on dev -> cannot reach main via merge either.
DESCRIPTION.md


# Editor / OS noise

.vscode/
.cursor/
.idea/
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
*~
